# Telegram Bot API token (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz

# Пароль для входа в админ-панель (клик 5 раз по заголовку)
ADMIN_PASSWORD=мой_надёжный_пароль

# URL базы данных (SQLite — для разработки)
DATABASE_URL=sqlite:///./barber.db

# PostgreSQL (для продакшена — опционально)
# DATABASE_URL=postgresql://user:password@localhost:5432/barber_db

# Базовый URL приложения (заполняется автоматически при deploy.sh)
# BASE_URL=https://что-то.trycloudflare.com
